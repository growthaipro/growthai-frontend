{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@admatrix/shared-types": ["packages/shared-types/src"],
      "@admatrix/ai-engine": ["packages/ai-engine/src"],
      "@admatrix/integrations": ["packages/integrations/src"],
      "@admatrix/core": ["packages/core/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
