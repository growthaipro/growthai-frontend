// ============================================================
// AdMatrix AI — Prisma Schema
// Production-grade multi-tenant DB design
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organization (Tenant) ────────────────────────────────────

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members     OrganizationMember[]
  campaigns   Campaign[]
  apiTokens   ApiToken[]

  @@map("organizations")
}

// ─── Users ───────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships  OrganizationMember[]
  refreshTokens RefreshToken[]

  @@map("users")
}

// ─── RBAC ────────────────────────────────────────────────────

model OrganizationMember {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  role           String   @default("VIEWER")
  createdAt      DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("organization_members")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model ApiToken {
  id             String   @id @default(uuid())
  name           String
  token          String   @unique
  organizationId String   @map("organization_id")
  scopes         String[]
  expiresAt      DateTime? @map("expires_at")
  lastUsedAt     DateTime? @map("last_used_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("api_tokens")
}

// ─── Campaigns (Domain Aggregate) ────────────────────────────

model Campaign {
  id               String   @id @default(uuid())
  organizationId   String   @map("organization_id")
  name             String
  objective        String
  platform         String
  status           String   @default("DRAFT")
  budgetTotal      Decimal  @map("budget_total") @db.Decimal(12, 2)
  budgetDaily      Decimal  @map("budget_daily") @db.Decimal(12, 2)
  optimizationMode String   @default("MANUAL") @map("optimization_mode")
  externalId       String?  @map("external_id")
  aiScore          Int?     @map("ai_score")
  startAt          DateTime @map("start_at")
  endAt            DateTime? @map("end_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creatives        Creative[]
  metrics          CampaignMetric[]
  optimizationLogs OptimizationLog[]

  @@index([organizationId])
  @@index([status])
  @@index([platform])
  @@map("campaigns")
}

// ─── Creatives ────────────────────────────────────────────────

model Creative {
  id               String  @id @default(uuid())
  campaignId       String  @map("campaign_id")
  name             String
  type             String
  aiGenerated      Boolean @default(false) @map("ai_generated")
  assetUrl         String? @map("asset_url")
  headline         String?
  description      String?
  performanceScore Int?    @map("performance_score")
  status           String  @default("ACTIVE")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("creatives")
}

// ─── Metrics (Time-Series Optimized) ─────────────────────────

model CampaignMetric {
  id          String   @id @default(uuid())
  campaignId  String   @map("campaign_id")
  timestamp   DateTime
  impressions BigInt   @default(0)
  clicks      BigInt   @default(0)
  conversions BigInt   @default(0)
  spend       Decimal  @default(0) @db.Decimal(12, 2)
  revenue     Decimal  @default(0) @db.Decimal(12, 2)
  ctr         Decimal  @default(0) @db.Decimal(8, 4)
  cpa         Decimal  @default(0) @db.Decimal(12, 2)
  roas        Decimal  @default(0) @db.Decimal(8, 4)
  platform    String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, timestamp(sort: Desc)])
  @@index([timestamp])
  @@map("campaign_metrics")
}

// ─── Optimization Logs (Data Moat) ───────────────────────────

model OptimizationLog {
  id          String   @id @default(uuid())
  campaignId  String   @map("campaign_id")
  action      String
  reason      String
  metadata    Json     @default("{}")
  triggeredBy String   @default("AI") @map("triggered_by")
  createdAt   DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([createdAt(sort: Desc)])
  @@map("optimization_logs")
}
