{
  "extends": "../../tsconfig.json",
  "compilerOptions": {

    "rootDir": "../../",
    "outDir": "./dist",

    "module": "commonjs",
    "target": "ES2020",

    "declaration": true,
    "sourceMap": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "allowSyntheticDefaultImports": true,

    "baseUrl": "./",

    "paths": {
  "@admatrix/shared-types": ["../../packages/shared-types/dist"]
}
      ]
    },

    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false
  },

  "include": [
    "src/**/*",
    "../../packages/shared-types/src/**/*"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}