# ========================================
# AdMatrix AI — Environment Variables
# ========================================

# App
NODE_ENV=development
APP_PORT=3001
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/admatrix_dev?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Meta (Facebook) API
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# Google Ads API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DEVELOPER_TOKEN=
GOOGLE_REFRESH_TOKEN=

# TikTok Ads API
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=

# AI / OpenAI (for creative generation)
OPENAI_API_KEY=

# Bull Queue Dashboard
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=admin123
